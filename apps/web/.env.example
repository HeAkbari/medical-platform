# apps/web environment — copy to .env.local to run the web app.
#   cp apps/web/.env.example apps/web/.env.local

# Phase 1: read live data from the local HAPI FHIR server (docs/oscar).
# Set to "mock" to use the in-memory sample data instead (no Docker needed).
DATA_SOURCE=fhir
FHIR_BASE_URL=http://localhost:8080/fhir

# Phase 2 (OSCAR sandbox): swap the URL above and set the bearer token.
# FHIR_TOKEN=
