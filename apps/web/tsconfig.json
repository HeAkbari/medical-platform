{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@medical-platform/domain": ["../../packages/domain/src/index.ts"],
      "@medical-platform/domain/validation": ["../../packages/domain/src/validation/schemas.ts"],
      "@medical-platform/domain/*": ["../../packages/domain/src/*"],
      "@medical-platform/auth": ["../../packages/auth/src/index.ts"],
      "@medical-platform/policies": ["../../packages/policies/src/index.ts"]
    }
  },
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
