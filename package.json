{
  "name": "@medical-platform/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "postinstall": "node ./scripts/patch-nx-console-pm.js",
    "fix-nx-console": "node ./scripts/patch-nx-console-pm.js",
    "dev": "turbo dev --filter=@medical-platform/web",
    "dev:web": "turbo dev --filter=@medical-platform/web",
    "dev:api": "turbo dev --filter=@medical-platform/api",
    "build": "turbo build",
    "start": "turbo start --filter=@medical-platform/web",
    "lint": "turbo lint",
    "setup": "bun install"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "~15.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.28.0",
    "@nx/eslint": "22.3.3",
    "@nx/eslint-plugin": "22.3.3",
    "@nx/js": "22.3.3",
    "@nx/next": "22.3.3",
    "@nx/react": "22.3.3",
    "@nx/workspace": "22.3.3",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.33",
    "@swc/helpers": "0.5.21",
    "eslint": "^9.28.0",
    "eslint-config-next": "~15.2.4",
    "nx": "22.3.3",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "tslib": "^2.8.1",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.59.4"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "core-js",
    "esbuild",
    "lmdb",
    "msgpackr-extract",
    "nx"
  ]
}
