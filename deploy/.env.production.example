# Copy to deploy/.env on the VPS and adjust if ports conflict with other apps.
#
#   cp deploy/.env.production.example deploy/.env

# Host ports (change if already in use on the VPS)
WEB_HOST_PORT=3002
HAPI_HOST_PORT=8082

# HAPI PostgreSQL password (change in production)
HAPI_DB_PASSWORD=hapi

# JVM heap for HAPI on small VPS (increase if server has 4GB+ RAM)
HAPI_JAVA_OPTS=-Xms256m -Xmx768m
