# Medical Platform — environment template

# Web
NEXT_PUBLIC_API_URL=/api

# Data source: "mock" (default, in-memory) or "fhir" (FHIR R4 server).
# For phase 1 testing, point at the local HAPI FHIR server (docs/oscar).
# For phase 2, swap FHIR_BASE_URL/FHIR_TOKEN for the OSCAR sandbox.
DATA_SOURCE=mock
FHIR_BASE_URL=http://localhost:8080/fhir
# FHIR_TOKEN=

# API (when NestJS backend is implemented)
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medical_platform
REDIS_URL=redis://localhost:6379
